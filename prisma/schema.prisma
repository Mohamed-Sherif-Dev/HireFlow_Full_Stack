generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          UserRole  @default(CANDIDATE)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts      Account[]
  sessions      Session[]
  candidate     Candidate?
  company       Company?
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Candidate {
  id          String   @id @default(cuid())
  userId      String   @unique
  title       String?
  bio         String?
  location    String?
  cvUrl       String?
  cvPublicId  String?
  skills      String[]
  experience  Int      @default(0)
  education   String?
  portfolio   String?
  linkedin    String?
  github      String?
  available   Boolean  @default(true)
  aiProfile   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id])
  applications Application[]
}

model Company {
  id          String   @id @default(cuid())
  userId      String   @unique
  name        String
  logo        String?
  logoPublicId String?
  website     String?
  industry    String?
  size        String?
  location    String?
  description String?
  verified    Boolean  @default(false)
  plan        Plan     @default(FREE)
  stripeId    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User  @relation(fields: [userId], references: [id])
  jobs Job[]
}

model Job {
  id           String     @id @default(cuid())
  companyId    String
  title        String
  description  String
  requirements String[]
  skills       String[]
  location     String
  type         JobType    @default(FULL_TIME)
  remote       Boolean    @default(false)
  salaryMin    Int?
  salaryMax    Int?
  experience   Int        @default(0)
  status       JobStatus  @default(ACTIVE)
  featured     Boolean    @default(false)
  views        Int        @default(0)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  expiresAt    DateTime?

  company      Company       @relation(fields: [companyId], references: [id])
  applications Application[]
}

model Application {
  id            String            @id @default(cuid())
  jobId         String
  candidateId   String
  coverLetter   String?
  aiScore       Int?
  aiReasoning   String?
  aiStrengths   String[]
  aiWeaknesses  String[]
  status        ApplicationStatus @default(PENDING)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  job       Job       @relation(fields: [jobId], references: [id])
  candidate Candidate @relation(fields: [candidateId], references: [id])

  @@unique([jobId, candidateId])
}

enum UserRole {
  CANDIDATE
  COMPANY
  ADMIN
}

enum Plan {
  FREE
  PRO
  ENTERPRISE
}

enum JobType {
  FULL_TIME
  PART_TIME
  CONTRACT
  FREELANCE
  INTERNSHIP
}

enum JobStatus {
  ACTIVE
  PAUSED
  CLOSED
}

enum ApplicationStatus {
  PENDING
  REVIEWING
  SHORTLISTED
  REJECTED
  ACCEPTED
}